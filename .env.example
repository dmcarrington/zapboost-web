# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/zapboost

# JWT secret for session tokens (generate with: openssl rand -base64 32)
JWT_SECRET=your-secret-here

# Shared secret for the cron ingest endpoint (/api/cron/ingest).
# Vercel Cron sends this automatically as `Authorization: Bearer <value>`
# when set on the project. Generate with: openssl rand -base64 32
CRON_SECRET=your-cron-secret-here

# LNbits integration (optional — omit for dev mode with simulated payments)
# LNBITS_URL=https://your-lnbits-instance.com
# LNBITS_API_KEY=your-invoice-read-key
